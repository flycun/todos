# Database
# 本地开发使用 SQLite（文件数据库）
DATABASE_URL="file:./dev.db"

# 生产环境使用云数据库（PostgreSQL/MySQL）
# 示例格式（使用以下之一）：
# PostgreSQL: "postgresql://user:password@host:port/database"
# MySQL: "mysql://user:password@host:port/database"
# Vercel Postgres: "postgresql://user:password@host.port/database?sslmode=require"
# Supabase: "postgresql://postgres:[YOUR-PASSWORD]@db.YOUR-PROJECT.supabase.co:5432/postgres"

# NextAuth
# 生产环境必须使用强随机密钥
# 生成方法: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# 本地开发
NEXTAUTH_URL="http://localhost:3000"

# 生产环境（在 Vercel 环境变量中设置）
# NEXTAUTH_URL="https://your-app.vercel.app"

# OAuth Providers (Optional)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GITHUB_ID=""
# GITHUB_SECRET=""
