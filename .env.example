# Database
# 本地开发使用 SQLite（文件数据库）
# DATABASE_URL="file:./dev.db"

# 生产环境使用云 PostgreSQL
# 推荐 Supabase（免费 500MB）：https://supabase.com
# Supabase 连接串格式（Dashboard → Project Settings → Database → Connection string）：
#   "postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres"
# 注意：Prisma 必须用端口 6543（Transaction/Pooler 模式），不要用直连 5432。
DATABASE_URL="postgresql://user:password@host:6543/database"

# NextAuth
# 生产环境必须使用强随机密钥
# 生成方法: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# 本地开发
NEXTAUTH_URL="http://localhost:3000"
# 生产环境设为 EdgeOne 分配的域名，例如：
# NEXTAUTH_URL="https://todo-app.edgeone.app"

# Server Actions 允许的来源（逗号分隔，对应部署域名）
# 生产环境（EdgeOne）设置为你的域名：
# ALLOWED_ORIGINS="todo-app.edgeone.app"
ALLOWED_ORIGINS="localhost:3000"

# OAuth Providers (Optional)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GITHUB_ID=""
# GITHUB_SECRET=""
